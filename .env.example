# ── Anthropic (Claude) ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Deepgram (STT) ────────────────────────────────────────────────────────────
DEEPGRAM_API_KEY=...

# ── ElevenLabs (TTS + Voice Clone) ───────────────────────────────────────────
ELEVENLABS_API_KEY=...
ELEVENLABS_VOICE_ID=...   # Get this after cloning your voice in the ElevenLabs dashboard

# ── LiveKit (WebRTC transport) ────────────────────────────────────────────────
# Use LiveKit Cloud (https://cloud.livekit.io) or self-host
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=API...
LIVEKIT_API_SECRET=...

# ── Agent persona ─────────────────────────────────────────────────────────────
AGENT_NAME=Armand
# SYSTEM_PROMPT is set here — leave blank to use the default in config.py
# SYSTEM_PROMPT=You are Armand. ...
